            "providers": [
                "Rimba\\Floorplan\\FloorplanServiceProvider"
            ]
        }
    },
    "autoload": {
        "psr-4": {
           "Rimba\\Floorplan\\": "src/"
        }
    },
    "minimum-stability": "alpha",
    "prefer-stable": true
}
