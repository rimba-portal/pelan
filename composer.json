{
    "name": "rimba/pelan",
    "description": "Models physical spaces (buildings, rooms, zones) for location-aware operations.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "BIT Ecosystem",
            "email": "bit.ecosystem@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "rimba/asas": "^1.0",
        "rimba/pihak": "^1.0"
    },
    "extra": {
